5.6 HPA Configuration
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
name: pyroscope-distributor-hpa
namespace: observability-pyroscope
spec:
scaleTargetRef:
apiVersion: apps/v1
kind: Deployment
name: pyroscope-distributor
minReplicas: 2
maxReplicas: 6
metrics:
- type: Resource
resource:
name: cpu
target:
type: Utilization
averageUtilization: 70
---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
name: pyroscope-querier-hpa
namespace: observability-pyroscope
spec:
scaleTargetRef:
apiVersion: apps/v1
kind: Deployment
name: pyroscope-querier
minReplicas: 2
maxReplicas: 8
metrics:
- type: Resource
resource:
name: cpu
target:
type: Utilization
averageUtilization: 60
Note: Do NOT HPA ingesters — they are StatefulSets with ring membership. Scale them manually
and wait for ring rebalance.
