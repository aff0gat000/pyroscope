VERTX -- "ALLOW :4040\nNetPol: ingress from appns" --> DIST
GRAFANA -- "ALLOW :4040\nNetPol: ingress from grafns" --> QF
DIST -- "ALLOW :9095\nNetPol: internal" --> ING
QF -- "ALLOW :9095\nNetPol: internal" --> QR
QR -- "ALLOW :9095\nNetPol: internal" --> ING
QR -- "ALLOW :9095\nNetPol: internal" --> SG
ING -- "ALLOW :9000\nNetPol: egress to minio" --> MINIO
SG -- "ALLOW :9000\nNetPol: egress to minio" --> MINIO
